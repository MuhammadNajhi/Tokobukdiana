<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
<title>Kasir Buk Diana</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#1C2B2A;
    --ink-soft:#3C4C4A;
    --paper:#F6F1E4;
    --paper-dim:#EDE4CE;
    --card:#FFFDF7;
    --teal:#24504D;
    --teal-deep:#173634;
    --teal-light:#3A7A72;
    --gold:#C79A3D;
    --gold-soft:#E7D6A4;
    --red:#A8412C;
    --green:#4C7A4F;
    --line: rgba(28,43,42,0.14);
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{
    margin:0;
    font-family:'Inter',sans-serif;
    background:var(--paper);
    color:var(--ink);
    overscroll-behavior:none;
  }
  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.001ms !important; transition-duration:0.001ms !important;}
  }
  .app{
    max-width:480px;
    margin:0 auto;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    background:var(--paper);
    position:relative;
    box-shadow:0 0 40px rgba(0,0,0,0.08);
  }

  /* HEADER */
  header.top{
    background:var(--teal-deep);
    color:var(--paper);
    padding:18px 18px 22px;
    position:relative;
    border-bottom:3px solid var(--gold);
  }
  .top-row{display:flex; align-items:center; gap:12px;}
  .stamp{
    width:46px; height:46px; border-radius:50%;
    border:2px solid var(--gold);
    display:flex; align-items:center; justify-content:center;
    font-family:'Fraunces',serif; font-weight:700; font-size:17px;
    color:var(--gold);
    flex-shrink:0;
    transform:rotate(-6deg);
  }
  .top-titles{flex:1; min-width:0;}
  .top-titles h1{
    font-family:'Fraunces',serif; font-weight:600; font-size:21px;
    margin:0; letter-spacing:0.2px;
  }
  .top-titles p{margin:2px 0 0; font-size:12.5px; color:var(--gold-soft); font-family:'Space Mono',monospace;}

  /* TABS CONTENT */
  main{flex:1; padding:16px 16px 110px; overflow-y:auto;}
  .tab{display:none;}
  .tab.active{display:block; animation:fadein .18s ease;}
  @keyframes fadein{from{opacity:0; transform:translateY(4px);} to{opacity:1; transform:translateY(0);}}

  .section-title{
    font-family:'Fraunces',serif; font-weight:600; font-size:16.5px;
    margin:2px 0 12px; color:var(--teal-deep);
    display:flex; align-items:center; justify-content:space-between;
  }

  /* SEARCH + CHIPS */
  .searchbar{
    display:flex; align-items:center; gap:8px;
    background:var(--card); border:1px solid var(--line);
    border-radius:10px; padding:9px 12px; margin-bottom:10px;
  }
  .searchbar input{
    border:none; outline:none; background:transparent; flex:1;
    font-family:'Inter'; font-size:14px; color:var(--ink);
  }
  .chips{display:flex; gap:7px; overflow-x:auto; padding-bottom:12px; margin-bottom:2px;}
  .chip{
    flex-shrink:0; padding:6px 13px; border-radius:99px; font-size:12.5px;
    background:var(--paper-dim); border:1px solid var(--line); color:var(--ink-soft);
    cursor:pointer; white-space:nowrap; font-weight:500;
  }
  .chip.active{background:var(--teal); border-color:var(--teal); color:#fff;}

  /* PRODUCT GRID */
  .grid{display:grid; grid-template-columns:1fr 1fr; gap:10px;}
  .pcard{
    background:var(--card); border:1px solid var(--line); border-radius:12px;
    padding:12px; cursor:pointer; position:relative; transition:transform .1s;
    display:flex; flex-direction:column; gap:6px; min-height:104px;
  }
  .pcard:active{transform:scale(0.96);}
  .pcard .pname{font-size:13.5px; font-weight:600; line-height:1.25; color:var(--ink);}
  .pcard .pprice{font-family:'Space Mono',monospace; font-size:13.5px; color:var(--teal); font-weight:700; margin-top:auto;}
  .pcard .pstock{font-size:10.5px; color:var(--ink-soft); font-weight:500;}
  .pcard .pstock.low{color:var(--red); font-weight:700;}
  .pcard .badge-qty{
    position:absolute; top:-7px; right:-7px; background:var(--gold); color:var(--teal-deep);
    border-radius:50%; width:22px; height:22px; font-size:11.5px; font-weight:700;
    display:flex; align-items:center; justify-content:center; border:2px solid var(--paper);
  }
  .empty{
    text-align:center; padding:40px 16px; color:var(--ink-soft);
  }
  .empty .big{font-family:'Fraunces',serif; font-size:16px; color:var(--teal-deep); margin-bottom:6px;}

  /* CART BAR */
  .cartbar{
    position:fixed; left:0; right:0; bottom:64px; max-width:480px; margin:0 auto;
    background:var(--teal); color:#fff; padding:12px 16px; display:none;
    align-items:center; justify-content:space-between; cursor:pointer;
    border-top:2px solid var(--gold);
  }
  .cartbar.show{display:flex;}
  .cartbar .ct-left{display:flex; flex-direction:column;}
  .cartbar .ct-left span.small{font-size:10.5px; color:var(--gold-soft); font-family:'Space Mono',monospace;}
  .cartbar .ct-left span.big{font-family:'Space Mono',monospace; font-weight:700; font-size:16px;}
  .cartbar button{
    background:var(--gold); color:var(--teal-deep); border:none; padding:9px 16px;
    border-radius:9px; font-weight:700; font-size:13px; font-family:'Inter';
  }

  /* BOTTOM NAV */
  nav.bottom{
    position:fixed; left:0; right:0; bottom:0; max-width:480px; margin:0 auto;
    background:var(--card); border-top:1px solid var(--line);
    display:flex; height:64px; z-index:20;
  }
  nav.bottom button{
    flex:1; background:none; border:none; display:flex; flex-direction:column;
    align-items:center; justify-content:center; gap:3px; color:var(--ink-soft);
    font-family:'Inter'; font-size:10.5px; font-weight:600; cursor:pointer;
  }
  nav.bottom button.active{color:var(--teal);}
  nav.bottom svg{width:20px; height:20px;}

  /* CARDS / LISTS (produk, riwayat) */
  .row-card{
    background:var(--card); border:1px solid var(--line); border-radius:12px;
    padding:12px 14px; margin-bottom:9px; display:flex; align-items:center; gap:10px;
  }
  .row-card .rinfo{flex:1; min-width:0;}
  .row-card .rname{font-size:13.5px; font-weight:600;}
  .row-card .rmeta{font-size:11.5px; color:var(--ink-soft); margin-top:2px; font-family:'Space Mono',monospace;}
  .icon-btn{
    width:32px; height:32px; border-radius:8px; border:1px solid var(--line);
    background:var(--paper-dim); display:flex; align-items:center; justify-content:center; cursor:pointer;
  }
  .icon-btn.danger{color:var(--red); border-color:rgba(168,65,44,0.3);}
  .icon-btn svg{width:15px; height:15px;}

  .fab{
    position:fixed; right:calc(50% - 240px + 16px); bottom:82px; z-index:15;
    background:var(--teal); color:#fff; border:none; border-radius:50%;
    width:52px; height:52px; box-shadow:0 6px 16px rgba(23,54,52,0.35);
    font-size:26px; display:flex; align-items:center; justify-content:center; cursor:pointer;
  }
  @media (max-width:480px){ .fab{ right:16px; } }

  /* trx history */
  .date-head{font-size:11px; text-transform:uppercase; letter-spacing:0.6px; color:var(--ink-soft); margin:14px 0 8px; font-weight:700;}
  .date-head:first-child{margin-top:0;}
  .trx-row{cursor:pointer;}
  .trx-total{font-family:'Space Mono',monospace; font-weight:700; color:var(--teal-deep); font-size:14px;}

  /* report cards */
  .stat-grid{display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px;}
  .stat-card{
    background:var(--teal-deep); color:var(--paper); border-radius:12px; padding:14px;
    border-bottom:3px solid var(--gold);
  }
  .stat-card .label{font-size:10.5px; color:var(--gold-soft); text-transform:uppercase; letter-spacing:0.4px;}
  .stat-card .value{font-family:'Space Mono',monospace; font-weight:700; font-size:17px; margin-top:5px;}
  .bar-row{display:flex; align-items:center; gap:8px; margin-bottom:9px;}
  .bar-row .bname{width:88px; flex-shrink:0; font-size:12px; font-weight:600; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;}
  .bar-track{flex:1; height:9px; background:var(--paper-dim); border-radius:99px; overflow:hidden;}
  .bar-fill{height:100%; background:linear-gradient(90deg, var(--teal-light), var(--teal));}
  .bar-qty{font-family:'Space Mono',monospace; font-size:11px; color:var(--ink-soft); width:34px; text-align:right;}

  /* MODAL / SHEET */
  .overlay{
    position:fixed; inset:0; background:rgba(23,32,31,0.5); z-index:30; display:none;
    align-items:flex-end; justify-content:center;
  }
  .overlay.show{display:flex; animation:fadein2 .15s ease;}
  @keyframes fadein2{from{opacity:0;} to{opacity:1;}}
  .sheet{
    background:var(--paper); width:100%; max-width:480px; border-radius:18px 18px 0 0;
    max-height:88vh; overflow-y:auto; padding:18px 18px calc(env(safe-area-inset-bottom,0px) + 18px);
    position:relative;
  }
  .sheet::before{
    content:''; display:block; width:38px; height:4px; background:var(--line);
    border-radius:99px; margin:0 auto 14px;
  }
  .sheet h2{font-family:'Fraunces',serif; font-size:18px; margin:0 0 14px; color:var(--teal-deep);}
  .field{margin-bottom:12px;}
  .field label{display:block; font-size:12px; font-weight:600; color:var(--ink-soft); margin-bottom:5px;}
  .field input, .field select{
    width:100%; padding:11px 12px; border:1px solid var(--line); border-radius:9px;
    font-family:'Inter'; font-size:14.5px; background:var(--card); color:var(--ink);
  }
  .field input:focus, .field select:focus{outline:2px solid var(--teal-light); border-color:var(--teal-light);}
  .btn{
    width:100%; padding:13px; border:none; border-radius:10px; font-weight:700; font-size:14.5px;
    cursor:pointer; font-family:'Inter';
  }
  .btn-primary{background:var(--teal); color:#fff;}
  .btn-primary:disabled{background:#9AA9A6; cursor:not-allowed;}
  .btn-ghost{background:transparent; color:var(--red); border:1px solid rgba(168,65,44,0.35); margin-top:8px;}
  .btn-gold{background:var(--gold); color:var(--teal-deep);}

  .cart-line{display:flex; align-items:center; gap:10px; padding:9px 0; border-bottom:1px dashed var(--line);}
  .cart-line .cl-info{flex:1; min-width:0;}
  .cart-line .cl-name{font-size:13px; font-weight:600;}
  .cart-line .cl-price{font-size:11.5px; color:var(--ink-soft); font-family:'Space Mono',monospace;}
  .stepper{display:flex; align-items:center; gap:8px;}
  .stepper button{
    width:26px; height:26px; border-radius:7px; border:1px solid var(--line); background:var(--card);
    font-size:15px; font-weight:700; color:var(--teal); cursor:pointer;
  }
  .stepper span{min-width:16px; text-align:center; font-family:'Space Mono',monospace; font-weight:700; font-size:13px;}

  .quickpay{display:flex; gap:7px; flex-wrap:wrap; margin-bottom:14px;}
  .quickpay button{
    padding:7px 12px; border-radius:8px; border:1px solid var(--line); background:var(--card);
    font-size:12.5px; font-weight:600; color:var(--teal-deep); cursor:pointer; font-family:'Space Mono',monospace;
  }

  .receipt{
    background:var(--card); border:1px dashed var(--ink-soft); border-radius:10px; padding:16px;
    font-family:'Space Mono',monospace; font-size:12.5px; color:var(--ink);
  }
  .receipt .rc-head{text-align:center; margin-bottom:10px;}
  .receipt .rc-head .n{font-family:'Fraunces',serif; font-weight:700; font-size:16px; color:var(--teal-deep);}
  .receipt .rc-line{display:flex; justify-content:space-between; margin:3px 0;}
  .receipt hr{border:none; border-top:1px dashed var(--ink-soft); margin:9px 0;}
  .receipt .rc-total{font-weight:700; font-size:14px;}

  .toast{
    position:fixed; top:14px; left:50%; transform:translateX(-50%); z-index:60;
    background:var(--teal-deep); color:var(--paper); padding:10px 18px; border-radius:99px;
    font-size:12.5px; font-weight:600; opacity:0; pointer-events:none; transition:opacity .2s, transform .2s;
    border:1px solid var(--gold);
  }
  .toast.show{opacity:1; transform:translateX(-50%) translateY(6px);}

  .swatch{display:flex; gap:8px; margin-bottom:12px;}
  .swatch div{width:24px; height:24px; border-radius:6px; border:1px solid var(--line);}
</style>
</head>
<body>
<div class="app">

  <header class="top">
    <div class="top-row">
      <div class="stamp">BD</div>
      <div class="top-titles">
        <h1>Kasir Buk Diana</h1>
        <p id="todayDate">memuat…</p>
      </div>
    </div>
  </header>

  <main>
    <!-- KASIR -->
    <section class="tab active" id="tab-kasir">
      <div class="searchbar">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#3C4C4A" stroke-width="2.3"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="searchInput" placeholder="Cari produk…" oninput="renderProductGrid()">
      </div>
      <div class="chips" id="categoryChips"></div>
      <div class="grid" id="productGrid"></div>
    </section>

    <!-- PRODUK -->
    <section class="tab" id="tab-produk">
      <div class="section-title">Daftar Produk</div>
      <div id="productList"></div>
      <div class="empty" id="produkEmpty" style="display:none;">
        <div class="big">Belum ada produk</div>
        Tambahkan produk pertama Buk Diana dengan tombol + di kanan bawah.
      </div>
    </section>

    <!-- RIWAYAT -->
    <section class="tab" id="tab-riwayat">
      <div class="section-title">Riwayat Transaksi</div>
      <div id="historyList"></div>
      <div class="empty" id="riwayatEmpty" style="display:none;">
        <div class="big">Belum ada transaksi</div>
        Transaksi yang sudah dibayar akan muncul di sini.
      </div>
    </section>

    <!-- LAPORAN -->
    <section class="tab" id="tab-laporan">
      <div class="section-title">Laporan Penjualan</div>
      <div class="stat-grid">
        <div class="stat-card"><div class="label">Hari Ini</div><div class="value" id="statToday">Rp0</div></div>
        <div class="stat-card"><div class="label">Transaksi Hari Ini</div><div class="value" id="statTodayCount">0</div></div>
        <div class="stat-card"><div class="label">7 Hari Terakhir</div><div class="value" id="statWeek">Rp0</div></div>
        <div class="stat-card"><div class="label">Total Transaksi</div><div class="value" id="statAllCount">0</div></div>
      </div>
      <div class="section-title" style="margin-top:4px;">Produk Terlaris</div>
      <div id="topProducts"></div>
      <div class="empty" id="laporanEmpty" style="display:none;">
        <div class="big">Belum ada data</div>
        Laporan akan terisi begitu ada transaksi pertama.
      </div>
    </section>
  </main>

  <!-- cart bar -->
  <div class="cartbar" id="cartBar" onclick="openCartSheet()">
    <div class="ct-left">
      <span class="small" id="cartCountLabel">0 item</span>
      <span class="big" id="cartTotalLabel">Rp0</span>
    </div>
    <button onclick="event.stopPropagation(); openCartSheet()">Lihat Keranjang</button>
  </div>

  <!-- fab for produk tab -->
  <button class="fab" id="fabAddProduct" style="display:none;" onclick="openProductForm()">+</button>

  <nav class="bottom">
    <button class="active" data-tab="kasir" onclick="switchTab('kasir')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      Kasir
    </button>
    <button data-tab="produk" onclick="switchTab('produk')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="M3.3 7 12 12l8.7-5"/><path d="M12 22V12"/></svg>
      Produk
    </button>
    <button data-tab="riwayat" onclick="switchTab('riwayat')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14.5"/></svg>
      Riwayat
    </button>
    <button data-tab="laporan" onclick="switchTab('laporan')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Laporan
    </button>
  </nav>
</div>

<div class="toast" id="toast"></div>

<!-- CART SHEET -->
<div class="overlay" id="cartOverlay" onclick="closeIfBackdrop(event,'cartOverlay')">
  <div class="sheet">
    <h2>Keranjang</h2>
    <div id="cartLines"></div>
    <div style="display:flex; justify-content:space-between; align-items:center; margin:14px 0;">
      <span style="font-weight:600; font-size:13.5px;">Total</span>
      <span class="trx-total" id="cartSheetTotal" style="font-size:18px;">Rp0</span>
    </div>
    <button class="btn btn-primary" id="btnGoCheckout" onclick="openCheckoutSheet()">Bayar</button>
    <button class="btn btn-ghost" onclick="clearCart()">Kosongkan Keranjang</button>
  </div>
</div>

<!-- CHECKOUT SHEET -->
<div class="overlay" id="checkoutOverlay" onclick="closeIfBackdrop(event,'checkoutOverlay')">
  <div class="sheet">
    <h2>Pembayaran</h2>
    <div style="display:flex; justify-content:space-between; margin-bottom:14px;">
      <span style="font-size:13px; color:var(--ink-soft);">Total Tagihan</span>
      <span class="trx-total" id="checkoutTotal" style="font-size:18px;">Rp0</span>
    </div>
    <div class="field">
      <label>Uang Diterima</label>
      <input id="cashInput" type="number" inputmode="numeric" placeholder="0" oninput="updateChange()">
    </div>
    <div class="quickpay" id="quickPayRow"></div>
    <div style="display:flex; justify-content:space-between; margin-bottom:16px;">
      <span style="font-size:13px; color:var(--ink-soft);">Kembalian</span>
      <span class="trx-total" id="changeAmount" style="color:var(--green);">Rp0</span>
    </div>
    <button class="btn btn-primary" id="btnConfirmPay" onclick="confirmCheckout()" disabled>Selesaikan Transaksi</button>
  </div>
</div>

<!-- RECEIPT SHEET -->
<div class="overlay" id="receiptOverlay">
  <div class="sheet">
    <h2>Transaksi Berhasil</h2>
    <div class="receipt" id="receiptBody"></div>
    <button class="btn btn-gold" style="margin-top:14px;" onclick="closeReceipt()">Selesai</button>
  </div>
</div>

<!-- PRODUCT FORM SHEET -->
<div class="overlay" id="productFormOverlay" onclick="closeIfBackdrop(event,'productFormOverlay')">
  <div class="sheet">
    <h2 id="productFormTitle">Tambah Produk</h2>
    <input type="hidden" id="editProductId">
    <div class="field">
      <label>Nama Produk</label>
      <input id="pfName" placeholder="Contoh: Kopi Sachet">
    </div>
    <div class="field">
      <label>Kategori</label>
      <input id="pfCategory" placeholder="Contoh: Minuman" list="catList">
      <datalist id="catList"></datalist>
    </div>
    <div class="field">
      <label>Harga Jual (Rp)</label>
      <input id="pfPrice" type="number" inputmode="numeric" placeholder="0">
    </div>
    <div class="field">
      <label>Stok</label>
      <input id="pfStock" type="number" inputmode="numeric" placeholder="0">
    </div>
    <button class="btn btn-primary" onclick="saveProductForm()">Simpan Produk</button>
    <button class="btn btn-ghost" id="deleteProductBtn" style="display:none;" onclick="deleteProductConfirm()">Hapus Produk</button>
  </div>
</div>

<!-- TRX DETAIL SHEET -->
<div class="overlay" id="trxDetailOverlay" onclick="closeIfBackdrop(event,'trxDetailOverlay')">
  <div class="sheet">
    <h2>Detail Transaksi</h2>
    <div class="receipt" id="trxDetailBody"></div>
    <button class="btn btn-primary" style="margin-top:14px;" onclick="closeOverlay('trxDetailOverlay')">Tutup</button>
  </div>
</div>

<script>
/* ---------- STATE ---------- */
let products = [];
let transactions = [];
let cart = []; // {productId, qty}
let activeCategory = 'Semua';

/* ---------- STORAGE HELPERS ---------- */
async function loadProducts(){
  try{
    const r = await window.storage.get('bd_products', false);
    return r ? JSON.parse(r.value) : null;
  }catch(e){ return null; }
}
async function saveProducts(){
  try{ await window.storage.set('bd_products', JSON.stringify(products), false); }
  catch(e){ console.error('gagal simpan produk', e); showToast('Gagal menyimpan produk'); }
}
async function loadTransactions(){
  try{
    const r = await window.storage.get('bd_transactions', false);
    return r ? JSON.parse(r.value) : null;
  }catch(e){ return null; }
}
async function saveTransactions(){
  try{ await window.storage.set('bd_transactions', JSON.stringify(transactions), false); }
  catch(e){ console.error('gagal simpan transaksi', e); showToast('Gagal menyimpan transaksi'); }
}

const SEED_PRODUCTS = [
  {id:'p1', name:'Kopi Sachet', category:'Minuman', price:3000, stock:40},
  {id:'p2', name:'Teh Botol', category:'Minuman', price:5000, stock:24},
  {id:'p3', name:'Mie Instan Goreng', category:'Makanan', price:3500, stock:30},
  {id:'p4', name:'Roti Tawar', category:'Makanan', price:14000, stock:8},
  {id:'p5', name:'Sabun Mandi', category:'Kebutuhan', price:4500, stock:15},
  {id:'p6', name:'Gula Pasir 1kg', category:'Sembako', price:16000, stock:3},
];

async function init(){
  const p = await loadProducts();
  products = p !== null ? p : SEED_PRODUCTS;
  if(p === null) await saveProducts();
  const t = await loadTransactions();
  transactions = t !== null ? t : [];

  renderCategoryChips();
  renderProductGrid();
  renderProductList();
  renderHistory();
  renderReport();
  updateCartBar();
  setTodayDate();
}
init();

function setTodayDate(){
  const d = new Date();
  const opts = {weekday:'long', day:'numeric', month:'long', year:'numeric'};
  document.getElementById('todayDate').textContent = d.toLocaleDateString('id-ID', opts);
}

/* ---------- UTIL ---------- */
function rupiah(n){
  return 'Rp' + Math.round(n).toLocaleString('id-ID');
}
function uid(){ return 'id' + Date.now().toString(36) + Math.random().toString(36).slice(2,7); }
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(window.__toastTimer);
  window.__toastTimer = setTimeout(()=> t.classList.remove('show'), 1700);
}
function closeIfBackdrop(ev, id){
  if(ev.target.id === id) closeOverlay(id);
}
function closeOverlay(id){ document.getElementById(id).classList.remove('show'); }
function openOverlay(id){ document.getElementById(id).classList.add('show'); }

/* ---------- TABS ---------- */
function switchTab(name){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  document.querySelectorAll('nav.bottom button').forEach(b=>b.classList.toggle('active', b.dataset.tab===name));
  document.getElementById('fabAddProduct').style.display = (name==='produk') ? 'flex' : 'none';
  if(name==='laporan') renderReport();
  if(name==='riwayat') renderHistory();
}

/* ---------- CATEGORY CHIPS ---------- */
function renderCategoryChips(){
  const cats = ['Semua', ...new Set(products.map(p=>p.category||'Lainnya'))];
  const wrap = document.getElementById('categoryChips');
  wrap.innerHTML = cats.map(c=>`<div class="chip ${c===activeCategory?'active':''}" onclick="setCategory('${c.replace(/'/g,"\\'")}')">${c}</div>`).join('');
}
function setCategory(c){
  activeCategory = c;
  renderCategoryChips();
  renderProductGrid();
}

/* ---------- PRODUCT GRID (KASIR) ---------- */
function renderProductGrid(){
  const q = (document.getElementById('searchInput').value || '').toLowerCase().trim();
  const grid = document.getElementById('productGrid');
  let list = products.filter(p=>{
    const matchCat = activeCategory==='Semua' || (p.category||'Lainnya')===activeCategory;
    const matchQ = p.name.toLowerCase().includes(q);
    return matchCat && matchQ;
  });
  if(list.length===0){
    grid.innerHTML = '';
    grid.insertAdjacentHTML('afterend', '');
    document.getElementById('productGrid').innerHTML = `<div class="empty" style="grid-column:1/-1;"><div class="big">Produk tidak ditemukan</div>Coba kata kunci lain atau tambahkan produk baru di tab Produk.</div>`;
    return;
  }
  grid.innerHTML = list.map(p=>{
    const inCart = cart.find(c=>c.productId===p.id);
    const qty = inCart ? inCart.qty : 0;
    const low = p.stock <= 5;
    const outOfStock = p.stock <= 0;
    return `
    <div class="pcard" style="${outOfStock?'opacity:0.45; pointer-events:none;':''}" onclick="addToCart('${p.id}')">
      ${qty>0 ? `<div class="badge-qty">${qty}</div>` : ''}
      <div class="pname">${escapeHtml(p.name)}</div>
      <div class="pstock ${low?'low':''}">${outOfStock? 'Stok habis' : 'Stok: '+p.stock}</div>
      <div class="pprice">${rupiah(p.price)}</div>
    </div>`;
  }).join('');
}
function escapeHtml(s){
  return s.replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}

/* ---------- CART ---------- */
function addToCart(productId){
  const prod = products.find(p=>p.id===productId);
  if(!prod || prod.stock<=0) return;
  const line = cart.find(c=>c.productId===productId);
  const currentQty = line ? line.qty : 0;
  if(currentQty >= prod.stock){ showToast('Stok tidak cukup'); return; }
  if(line){ line.qty++; } else { cart.push({productId, qty:1}); }
  renderProductGrid();
  updateCartBar();
}
function changeCartQty(productId, delta){
  const line = cart.find(c=>c.productId===productId);
  if(!line) return;
  const prod = products.find(p=>p.id===productId);
  line.qty += delta;
  if(prod && line.qty > prod.stock){ line.qty = prod.stock; showToast('Stok tidak cukup'); }
  if(line.qty <= 0){ cart = cart.filter(c=>c.productId!==productId); }
  renderCartLines();
  renderProductGrid();
  updateCartBar();
}
function clearCart(){
  cart = [];
  renderCartLines();
  renderProductGrid();
  updateCartBar();
  closeOverlay('cartOverlay');
}
function cartTotal(){
  return cart.reduce((sum,c)=>{
    const p = products.find(pp=>pp.id===c.productId);
    return sum + (p ? p.price*c.qty : 0);
  },0);
}
function cartCount(){
  return cart.reduce((s,c)=>s+c.qty,0);
}
function updateCartBar(){
  const bar = document.getElementById('cartBar');
  if(cart.length===0){ bar.classList.remove('show'); return; }
  bar.classList.add('show');
  document.getElementById('cartCountLabel').textContent = cartCount()+' item';
  document.getElementById('cartTotalLabel').textContent = rupiah(cartTotal());
}
function openCartSheet(){
  if(cart.length===0){ showToast('Keranjang masih kosong'); return; }
  renderCartLines();
  openOverlay('cartOverlay');
}
function renderCartLines(){
  const wrap = document.getElementById('cartLines');
  if(cart.length===0){
    wrap.innerHTML = `<div class="empty"><div class="big">Keranjang kosong</div>Pilih produk dari tab Kasir.</div>`;
  }else{
    wrap.innerHTML = cart.map(c=>{
      const p = products.find(pp=>pp.id===c.productId);
      if(!p) return '';
      return `
      <div class="cart-line">
        <div class="cl-info">
          <div class="cl-name">${escapeHtml(p.name)}</div>
          <div class="cl-price">${rupiah(p.price)} x ${c.qty}</div>
        </div>
        <div class="stepper">
          <button onclick="changeCartQty('${p.id}',-1)">−</button>
          <span>${c.qty}</span>
          <button onclick="changeCartQty('${p.id}',1)">+</button>
        </div>
      </div>`;
    }).join('');
  }
  document.getElementById('cartSheetTotal').textContent = rupiah(cartTotal());
}

/* ---------- CHECKOUT ---------- */
function openCheckoutSheet(){
  closeOverlay('cartOverlay');
  document.getElementById('checkoutTotal').textContent = rupiah(cartTotal());
  document.getElementById('cashInput').value = '';
  document.getElementById('changeAmount').textContent = rupiah(0);
  document.getElementById('btnConfirmPay').disabled = true;
  renderQuickPay();
  openOverlay('checkoutOverlay');
  setTimeout(()=>document.getElementById('cashInput').focus(), 250);
}
function renderQuickPay(){
  const total = cartTotal();
  const opts = new Set();
  opts.add(total);
  [5000,10000,20000,50000,100000].forEach(step=>{
    const rounded = Math.ceil(total/step)*step;
    if(rounded > total || step===5000) opts.add(rounded);
  });
  const sorted = [...opts].sort((a,b)=>a-b).slice(0,4);
  document.getElementById('quickPayRow').innerHTML = sorted.map(v=>
    `<button onclick="setCash(${v})">${v===total? 'Uang Pas' : rupiah(v)}</button>`
  ).join('');
}
function setCash(v){
  document.getElementById('cashInput').value = v;
  updateChange();
}
function updateChange(){
  const total = cartTotal();
  const cash = Number(document.getElementById('cashInput').value) || 0;
  const change = cash - total;
  const el = document.getElementById('changeAmount');
  el.textContent = rupiah(Math.max(change,0));
  el.style.color = change < 0 ? 'var(--red)' : 'var(--green)';
  document.getElementById('btnConfirmPay').disabled = cash < total;
}
async function confirmCheckout(){
  const total = cartTotal();
  const cash = Number(document.getElementById('cashInput').value) || 0;
  if(cash < total) return;
  const items = cart.map(c=>{
    const p = products.find(pp=>pp.id===c.productId);
    return {name:p.name, price:p.price, qty:c.qty, subtotal:p.price*c.qty};
  });
  cart.forEach(c=>{
    const p = products.find(pp=>pp.id===c.productId);
    if(p) p.stock = Math.max(0, p.stock - c.qty);
  });
  const trx = {
    id: uid(),
    timestamp: new Date().toISOString(),
    items,
    total,
    cash,
    change: cash-total
  };
  transactions.unshift(trx);
  await saveProducts();
  await saveTransactions();
  closeOverlay('checkoutOverlay');
  showReceipt(trx);
  cart = [];
  updateCartBar();
  renderProductGrid();
  renderProductList();
}
function showReceipt(trx){
  const d = new Date(trx.timestamp);
  const timeStr = d.toLocaleString('id-ID', {day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'});
  document.getElementById('receiptBody').innerHTML = `
    <div class="rc-head">
      <div class="n">Kasir Buk Diana</div>
      <div>${timeStr}</div>
    </div>
    <hr>
    ${trx.items.map(it=>`
      <div class="rc-line"><span>${escapeHtml(it.name)} x${it.qty}</span><span>${rupiah(it.subtotal)}</span></div>
    `).join('')}
    <hr>
    <div class="rc-line rc-total"><span>Total</span><span>${rupiah(trx.total)}</span></div>
    <div class="rc-line"><span>Tunai</span><span>${rupiah(trx.cash)}</span></div>
    <div class="rc-line"><span>Kembalian</span><span>${rupiah(trx.change)}</span></div>
  `;
  openOverlay('receiptOverlay');
}
function closeReceipt(){
  closeOverlay('receiptOverlay');
  renderHistory();
  renderReport();
}

/* ---------- PRODUK TAB ---------- */
function renderProductList(){
  const wrap = document.getElementById('productList');
  const empty = document.getElementById('produkEmpty');
  if(products.length===0){
    wrap.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  wrap.innerHTML = products.map(p=>`
    <div class="row-card">
      <div class="rinfo">
        <div class="rname">${escapeHtml(p.name)}</div>
        <div class="rmeta">${escapeHtml(p.category||'Lainnya')} · ${rupiah(p.price)} · Stok ${p.stock}</div>
      </div>
      <div class="icon-btn" onclick="openProductForm('${p.id}')">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg>
      </div>
    </div>
  `).join('');
}
function openProductForm(id){
  const title = document.getElementById('productFormTitle');
  const delBtn = document.getElementById('deleteProductBtn');
  document.getElementById('catList').innerHTML = [...new Set(products.map(p=>p.category||''))].filter(Boolean).map(c=>`<option value="${c}">`).join('');
  if(id){
    const p = products.find(pp=>pp.id===id);
    title.textContent = 'Edit Produk';
    document.getElementById('editProductId').value = id;
    document.getElementById('pfName').value = p.name;
    document.getElementById('pfCategory').value = p.category||'';
    document.getElementById('pfPrice').value = p.price;
    document.getElementById('pfStock').value = p.stock;
    delBtn.style.display = 'block';
  }else{
    title.textContent = 'Tambah Produk';
    document.getElementById('editProductId').value = '';
    document.getElementById('pfName').value = '';
    document.getElementById('pfCategory').value = '';
    document.getElementById('pfPrice').value = '';
    document.getElementById('pfStock').value = '';
    delBtn.style.display = 'none';
  }
  openOverlay('productFormOverlay');
}
async function saveProductForm(){
  const id = document.getElementById('editProductId').value;
  const name = document.getElementById('pfName').value.trim();
  const category = document.getElementById('pfCategory').value.trim() || 'Lainnya';
  const price = Number(document.getElementById('pfPrice').value);
  const stock = Number(document.getElementById('pfStock').value);
  if(!name){ showToast('Nama produk wajib diisi'); return; }
  if(!price || price<=0){ showToast('Harga tidak valid'); return; }
  if(isNaN(stock) || stock<0){ showToast('Stok tidak valid'); return; }

  if(id){
    const p = products.find(pp=>pp.id===id);
    Object.assign(p, {name, category, price, stock});
    showToast('Produk diperbarui');
  }else{
    products.push({id: uid(), name, category, price, stock});
    showToast('Produk ditambahkan');
  }
  await saveProducts();
  closeOverlay('productFormOverlay');
  renderCategoryChips();
  renderProductGrid();
  renderProductList();
}
async function deleteProductConfirm(){
  const id = document.getElementById('editProductId').value;
  if(!id) return;
  products = products.filter(p=>p.id!==id);
  await saveProducts();
  closeOverlay('productFormOverlay');
  renderCategoryChips();
  renderProductGrid();
  renderProductList();
  showToast('Produk dihapus');
}

/* ---------- RIWAYAT TAB ---------- */
function renderHistory(){
  const wrap = document.getElementById('historyList');
  const empty = document.getElementById('riwayatEmpty');
  if(transactions.length===0){
    wrap.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  let lastDate = '';
  let html = '';
  transactions.forEach(trx=>{
    const d = new Date(trx.timestamp);
    const dateKey = d.toLocaleDateString('id-ID', {weekday:'long', day:'numeric', month:'long'});
    if(dateKey !== lastDate){
      html += `<div class="date-head">${dateKey}</div>`;
      lastDate = dateKey;
    }
    const timeStr = d.toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'});
    html += `
      <div class="row-card trx-row" onclick="showTrxDetail('${trx.id}')">
        <div class="rinfo">
          <div class="rname">${trx.items.length} item · ${timeStr}</div>
          <div class="rmeta">${trx.items.slice(0,2).map(i=>escapeHtml(i.name)).join(', ')}${trx.items.length>2?'…':''}</div>
        </div>
        <div class="trx-total">${rupiah(trx.total)}</div>
      </div>`;
  });
  wrap.innerHTML = html;
}
function showTrxDetail(id){
  const trx = transactions.find(t=>t.id===id);
  if(!trx) return;
  const d = new Date(trx.timestamp);
  const timeStr = d.toLocaleString('id-ID', {day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'});
  document.getElementById('trxDetailBody').innerHTML = `
    <div class="rc-head">
      <div class="n">Kasir Buk Diana</div>
      <div>${timeStr}</div>
    </div>
    <hr>
    ${trx.items.map(it=>`
      <div class="rc-line"><span>${escapeHtml(it.name)} x${it.qty}</span><span>${rupiah(it.subtotal)}</span></div>
    `).join('')}
    <hr>
    <div class="rc-line rc-total"><span>Total</span><span>${rupiah(trx.total)}</span></div>
    <div class="rc-line"><span>Tunai</span><span>${rupiah(trx.cash)}</span></div>
    <div class="rc-line"><span>Kembalian</span><span>${rupiah(trx.change)}</span></div>
  `;
  openOverlay('trxDetailOverlay');
}

/* ---------- LAPORAN TAB ---------- */
function isSameDay(a,b){
  return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
}
function renderReport(){
  const now = new Date();
  const weekAgo = new Date(now.getTime() - 7*24*60*60*1000);

  const todayTrx = transactions.filter(t=>isSameDay(new Date(t.timestamp), now));
  const weekTrx = transactions.filter(t=>new Date(t.timestamp) >= weekAgo);

  const todayTotal = todayTrx.reduce((s,t)=>s+t.total,0);
  const weekTotal = weekTrx.reduce((s,t)=>s+t.total,0);

  document.getElementById('statToday').textContent = rupiah(todayTotal);
  document.getElementById('statTodayCount').textContent = todayTrx.length;
  document.getElementById('statWeek').textContent = rupiah(weekTotal);
  document.getElementById('statAllCount').textContent = transactions.length;

  const qtyMap = {};
  transactions.forEach(t=>t.items.forEach(it=>{
    qtyMap[it.name] = (qtyMap[it.name]||0) + it.qty;
  }));
  const top = Object.entries(qtyMap).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const wrap = document.getElementById('topProducts');
  const empty = document.getElementById('laporanEmpty');
  if(top.length===0){
    wrap.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  const maxQty = top[0][1];
  wrap.innerHTML = top.map(([name,qty])=>`
    <div class="bar-row">
      <div class="bname">${escapeHtml(name)}</div>
      <div class="bar-track"><div class="bar-fill" style="width:${(qty/maxQty*100).toFixed(0)}%"></div></div>
      <div class="bar-qty">${qty}x</div>
    </div>
  `).join('');
}
</script>
